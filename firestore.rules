// ============================================================
// Firestore Security Rules for MyTube
// Firebase Console → Firestore Database → Rules → paste this, then Publish.
// ============================================================
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: readable by anyone, writable only by the owner
    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Videos: public/private read logic handled in the app (visibility field);
    // rules enforce that only the owner can write/delete their own videos.
    match /videos/{videoId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.owner;
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.owner ||
         // allow anyone signed in to bump views/likes counters only
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes']));
      allow delete: if request.auth != null && request.auth.uid == resource.data.owner;
    }

    // Likes: doc id is "{uid}_{videoId}" — only that user can create/delete their like
    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Comments: anyone can read, only signed-in users can post as themselves
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Subscriptions: doc id is "{uid}_{channelName}"
    match /subscriptions/{subId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.subscriberId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.subscriberId;
    }

    // Watch history: doc id is "{uid}_{videoId}" — private to the user
    match /watchHistory/{historyId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
