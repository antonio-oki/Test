// ============================================================
// Firebase Storage Security Rules for MyTube
// Firebase Console → Storage → Rules → paste this, then Publish.
// ============================================================
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Videos: anyone can view (playback), only the owning user can upload
    // into their own folder, matching path pattern videos/{uid}/{file}
    match /videos/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 200 * 1024 * 1024 // 200MB cap
                   && request.resource.contentType.matches('video/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /thumbnails/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
